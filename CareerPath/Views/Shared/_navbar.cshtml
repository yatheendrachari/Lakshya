@using Microsoft.AspNetCore.Identity
@using CareerPath.Models
 @inject SignInManager<ApplicationUser> SignInManager
 @inject UserManager<ApplicationUser> UserManager


<nav class="navbar navbar-expand-md navbar-light bg-white border-bottom fixed-top shadow-sm">
    <div class="container-fluid px-4">

        <!-- Logo -->
        <a class="navbar-brand d-flex align-items-center gap-2" href="/">
            <div class="rounded-3 d-flex align-items-center justify-content-center bg-primary text-white"
                 style="width: 2.25rem; height: 2.25rem;">
                <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M9.153 5.408C10.42 3.136 11.053 2 12 2c.947 0 1.58 1.136 2.847 3.408l.328.588c.36.646.54.969.82 1.182.28.213.63.292 1.33.45l.636.144c2.46.557 3.689.835 3.982 1.776.292.94-.546 1.921-2.223 3.882l-.434.507c-.476.557-.715.836-.822 1.18-.107.345-.071.717.001 1.46l.066.677c.253 2.617.38 3.925-.386 4.506-.766.582-1.918.051-4.22-1.009l-.597-.274c-.654-.302-.981-.452-1.328-.452-.347 0-.674.15-1.328.452l-.596.274c-2.303 1.06-3.455 1.59-4.22 1.01-.767-.582-.64-1.89-.387-4.507l.066-.676c.072-.744.108-1.116 0-1.46-.106-.345-.345-.624-.821-1.18l-.434-.508c-1.677-1.96-2.515-2.941-2.223-3.882.293-.941 1.523-1.22 3.983-1.776l.636-.144c.699-.158 1.048-.237 1.329-.45.28-.213.46-.536.82-1.182l.328-.588z"/>
                </svg>
            </div>
            <span class="fw-semibold fs-5 text-primary">
                CareerPath
            </span>
        </a>

        <!-- Mobile Toggle -->
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Navigation Links -->
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav mx-auto gap-4">
                <li class="nav-item">
                    <a class="nav-link text-dark" href="#how-it-works">How It Works</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark" href="#features">Features</a>
                </li>
                <li class="nav-item">
                    <a asp-area="Student" asp-controller="CareerPath" asp-action="Index" class="nav-link text-Dark">Career Path</a>
                </li>
                <li class="nav-item">
                    <a asp-area="Student" asp-controller="LearningPath" asp-action="Index" class="nav-link text-Dark">Learning Path</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark" asp-controller="Careers" asp-action="Index">Careers</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark" href="#about">About</a>
                </li>
            </ul>

            <!-- Auth Buttons -->
            <div class="d-flex align-items-center gap-2">
                @if (User.Identity.IsAuthenticated)
                {
                    <a class="btn btn-sm btn-outline-primary" asp-area="Student" asp-controller="Dashboard" asp-action="Index">
                        Dashboard
                    </a>
                    <form method="post" asp-area="Identity" asp-page="/Account/Logout" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-primary">
                            Logout
                        </button>
                    </form>
                }
                else
                {
                    <a class="btn btn-sm btn-outline-primary"
                       asp-area="Identity"
                       asp-page="/Account/Login">
                        Sign In
                    </a>
                    <a class="btn btn-sm btn-primary"
                       asp-area="Identity"
                       asp-page="/Account/Register">
                        Get Started
                    </a>
                }
            </div>
        </div>
    </div>
</nav>

<div style="height: 64px;"></div>
