@using Microsoft.AspNetCore.Identity
@using CareerPath.Models
 @inject SignInManager<ApplicationUser> SignInManager
 @inject UserManager<ApplicationUser> UserManager


<nav class="navbar navbar-expand-md navbar-white bg-dark border-bottom fixed-top shadow-sm">
    <div class="container-fluid px-4">

        <!-- Logo -->
        <a class="navbar-brand d-flex align-items-center gap-2" href="/">
            <img src="~/Images/icon1.png"  width="50" height="50" fill="currentColor" viewBox="0 0 24 24">
            </img>
            <span class="fw-bold fs-7 text-secondary text-purple" style="font-size: x-large">
                <strong>Lakshya</strong>
            </span>
        </a>

        <!-- Mobile Toggle -->
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Navigation Links -->
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav mx-auto gap-4">
                <li class="nav-item">
                    <a class="nav-link text-dark" href="#how-it-works">How It Works</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark" href="#features">Features</a>
                </li>
                <li class="nav-item">
                    <a asp-area="Student" asp-controller="CareerPath" asp-action="Index" class="nav-link text-Dark">Career Path</a>
                </li>
                <li class="nav-item">
                    <a asp-area="Student" asp-controller="LearningPath" asp-action="Index" class="nav-link text-Dark">Learning Path</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark" asp-area="Student" asp-controller="Careers" asp-action="Index">Careers</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark" href="#about">About</a>
                </li>
            </ul>

            <!-- Auth Buttons -->
            <div class="d-flex align-items-center gap-2">
                @if (User.Identity.IsAuthenticated)
                {
                    <a class="btn btn-sm btn-outline-light" asp-area="Student" asp-controller="Dashboard" asp-action="Index">
                        Dashboard
                    </a>
                    <form method="post" asp-area="Identity" asp-page="/Account/Logout" class="d-flex m-0 p-0">
                        <button type="submit" class="btn btn-sm btn-secondary">
                            Logout
                        </button>
                    </form>
                }
                else
                {
                    <a class="btn btn-sm btn-outline-secondary"
                       asp-area="Identity"
                       asp-page="/Account/Login">
                        Sign In
                    </a>
                    <a class="btn btn-sm btn-secondary"
                       asp-area="Identity"
                       asp-page="/Account/Register">
                        Get Started
                    </a>
                }
            </div>
        </div>
    </div>
</nav>

<div style="height: 64px;"></div>
