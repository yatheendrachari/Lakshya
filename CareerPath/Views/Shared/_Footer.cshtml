@* <script> *@
@*     const compact = document.getElementById('footer-compact'); *@
@*     const spacer  = document.getElementById('footer-spacer'); *@
@*     const full    = document.getElementById('footer-full'); *@
@* *@
@*     // Use IntersectionObserver — triggers only when the full footer *@
@*     // actually enters/leaves the viewport, avoiding any scroll loop. *@
@*     const observer = new IntersectionObserver( *@
@*         (entries) => { *@
@*             entries.forEach(entry => { *@
@*                 if (entry.isIntersecting) { *@
@*                     // Full footer is visible — hide compact bar + spacer *@
@*                     compact.style.opacity   = '0'; *@
@*                     compact.style.transform = 'translateY(100%)'; *@
@*                     spacer.style.display    = 'none'; *@
@*                 } else { *@
@*                     // Full footer is out of view — show compact bar + spacer *@
@*                     compact.style.opacity   = '1'; *@
@*                     compact.style.transform = 'translateY(0)'; *@
@*                     spacer.style.display    = 'block'; *@
@*                 } *@
@*             }); *@
@*         }, *@
@*         { *@
@*             // Trigger as soon as 1px of the full footer enters the viewport *@
@*             threshold: 0 *@
@*         } *@
@*     ); *@
@* *@
@*     observer.observe(full); *@
@* </script> *@




