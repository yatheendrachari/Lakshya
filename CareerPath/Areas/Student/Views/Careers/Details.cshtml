@model CareerPath.Models.ViewModels.CareerDetailViewModel

@section Styles {
    <link rel="stylesheet" href="~/css/Careers.css" />
}
<!-- TEMPDATA ERROR ALERT -->
@if (TempData["Error"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show mb-3" role="alert">
        <span>&#9888; @TempData["Error"]</span>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- BREADCRUMB -->
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/Student/Careers">Career Catalog</a></li>
        <li class="breadcrumb-item active">@Model.CareerName</li>
    </ol>
</nav>

<!-- MAIN TWO COLUMN LAYOUT -->
<div class="row g-0" style="min-height: calc(100vh - 120px);">

    <!-- ===================== LEFT — 3/4 CAREER DETAIL ===================== -->
    <div class="col-lg-9 career-detail-col">

        <!-- CAREER HEADER -->
        <div class="career-header mb-4">
            <div class="career-icon-wrap">
                @Model.FieldIcon
            </div>
            <div class="flex-grow-1">
                <h1 class="career-name">@Model.CareerName</h1>
                <p class="career-field-line">@Model.Field &middot; @Model.SubField</p>
                <div class="d-flex flex-wrap gap-2">
                    <span class="career-tag tag-field">@Model.Field</span>
                    <span class="career-tag tag-demand">@Model.DemandLevel Demand</span>
                    <span class="career-tag tag-exp">@Model.ExperienceLevel</span>
                    <span class="career-tag tag-work">@Model.WorkMode</span>
                </div>
            </div>
        </div>

        <!-- QUICK STATS -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="career-stat-card">
                    <div class="career-stat-val blue">@Model.AverageSalary</div>
                    <div class="career-stat-label">Avg. Salary</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="career-stat-card">
                    <div class="career-stat-val green">@Model.JobOpenings</div>
                    <div class="career-stat-label">Job Openings</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="career-stat-card">
                    <div class="career-stat-val amber">@Model.GrowthRate</div>
                    <div class="career-stat-label">Growth Rate</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="career-stat-card">
                    <div class="career-stat-val">@Model.TypicalDegree</div>
                    <div class="career-stat-label">Degree</div>
                </div>
            </div>
        </div>

        <!-- ABOUT THIS CAREER -->
        <div class="career-sec mb-4">
            <h5 class="career-sec-title">
                <span class="career-sec-dot"></span> About This Career
            </h5>
            <p class="career-description">@Model.Description</p>
        </div>

        <!-- WHAT YOU WILL DO -->
        <div class="career-sec mb-4">
            <h5 class="career-sec-title">
                <span class="career-sec-dot"></span> What You Will Do
            </h5>
            <ul class="resp-list">
                @foreach (var responsibility in Model.Responsibilities)
                {
                    <li><span class="text-muted">@responsibility</span></li>
                }
            </ul>
        </div>

        <!-- SKILLS REQUIRED -->
        <div class="career-sec mb-4">
            <h5 class="career-sec-title">
                <span class="career-sec-dot"></span> Skills Required
            </h5>
            <div class="skills-grid">
                @foreach (var skill in Model.RequiredSkills)
                {
                    <div class="skill-chip">
                        <div class="skill-chip-name">
                            <span>@skill.Name</span>
                            <span class="skill-chip-level">@skill.Level / 4</span>
                        </div>
                        <div class="skill-bar">
                            <div class="skill-bar-fill" style="width: @(skill.Level * 25)%;"></div>
                        </div>
                        <span class="skill-label">@skill.LevelLabel</span>
                    </div>
                }
            </div>
        </div>

        <!-- TYPICAL CAREER PROGRESSION -->
        <div class="career-sec mb-4">
            <h5 class="career-sec-title">
                <span class="career-sec-dot"></span> Typical Career Progression
            </h5>
            <div class="prog-steps">
                @for (int i = 0; i < Model.CareerProgression.Count; i++)
                {
                    <div class="prog-step">
                        <div class="prog-step-years">@Model.CareerProgression[i].YearsRange</div>
                        <div class="prog-step-title">@Model.CareerProgression[i].Title</div>
                    </div>
                    @if (i < Model.CareerProgression.Count - 1)
                    {
                        <span class="prog-arrow">&#8594;</span>
                    }
                }
            </div>
        </div>

        <!-- TOP COMPANIES HIRING -->
        <div class="career-sec mb-4">
            <h5 class="career-sec-title">
                <span class="career-sec-dot"></span> Top Companies Hiring
            </h5>
            <div class="company-chips">
                @foreach (var company in Model.TopCompanies)
                {
                    <span class="company-chip">@company</span>
                }
            </div>
        </div>

        <!-- RELATED CAREERS -->
        <div class="career-sec mb-4">
            <h5 class="career-sec-title">
                <span class="career-sec-dot"></span> Related Careers You Might Consider
            </h5>
            <div class="related-chips">
                @foreach (var related in Model.RelatedCareers)
                {
                    <a href="/Student/Careers/Details/@related.Slug" class="related-chip">@related.Name &rarr;</a>
                }
            </div>
        </div>

    </div>

    <!-- ===================== RIGHT — 1/4 GAP ANALYSIS PANEL ===================== -->
    <div class="col-lg-3 gap-panel-col">
        <div class="gap-panel-sticky">

            @if (Model.GapAnalysis == null)
            {
                <!-- GAP ANALYSIS CTA -->
                <div class="gap-cta-card mb-3">
                    <div class="text-center mb-3">
                        <div class="gap-cta-icon">&#127919;</div>
                        <div class="gap-cta-title">Am I Ready for This?</div>
                        <p class="gap-cta-sub">
                            Get a personalized gap analysis comparing your current profile against what this career requires.
                        </p>
                    </div>

                    <hr class="gap-divider">

                    <p class="gap-what-label">What you will get:</p>
                    <ul class="gap-benefit-list">
                        <li>
                            <span class="ico-green mt-1">&#10003;</span>
                            <span>Your <strong>readiness score</strong> out of 100 for this career</span>
                        </li>
                        <li>
                            <span class="ico-green mt-1">&#10003;</span>
                            <span>Skills where you <strong>already meet</strong> the requirement</span>
                        </li>
                        <li>
                            <span class="ico-amber mt-1">&#9888;</span>
                            <span>Skills with <strong>medium priority gaps</strong> to address</span>
                        </li>
                        <li>
                            <span class="ico-red mt-1">&#9679;</span>
                            <span>Skills with <strong>critical gaps</strong> that need immediate attention</span>
                        </li>
                        <li>
                            <span class="ico-blue mt-1">&#128218;</span>
                            <span>Actionable <strong>advice</strong> for each gap</span>
                        </li>
                    </ul>

                    <form method="post"
                          asp-area="Student"
                          asp-controller="Careers"
                          asp-action="GapAnalysis"
                          id="gapForm">
                        <input type="hidden" name="careerName" value="@Model.CareerName" />
                        <input type="hidden" name="slug"       value="@Model.Slug" />
                        <button type="submit"
                                class="btn-run-gap"
                                id="gapBtn"
                                onclick="showLoading(this)">
                            Run Gap Analysis
                        </button>
                    </form>

                    <p class="gap-hint-text">Based on your resume, GitHub, and questionnaire</p>
                </div>

                <div class="gap-tip-card">
                    <p class="mb-0 text-center">
                        &#128161; <strong>Tip:</strong> Complete your profile first for the most accurate analysis.
                        <a href="/Student/Onboarding">Update Profile &rarr;</a>
                    </p>
                </div>
            }
            else
            {
                <!-- GAP ANALYSIS RESULT -->
                <partial name="_GapAnalysisResult"
                         model="Model.GapAnalysis"
                         view-data='new ViewDataDictionary(ViewData) { { "CareerName", Model.CareerName }, { "CareerSlug", Model.Slug } }' />
            }

        </div>
    </div>

</div>

@section Scripts {
    <script>
    function showLoading(btn) {
        setTimeout(() => {
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status"></span>Analyzing&hellip;';
        }, 10);
    }
    </script>
}