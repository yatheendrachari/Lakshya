@* Areas/Student/Views/Careers/_GapAnalysisResult.cshtml *@
@model CareerPath.Models.ViewModels.GapAnalysisViewModel

@{
  var score         = Model.ReadinessScore;
  var circumference = 251.2;
  var ringColor     = score >= 70 ? "#34d399" : score >= 50 ? "#fbbf24" : "#f87171";
}

<div class="gap-result">

  <div class="gap-readiness-card">
    <div class="gap-readiness-label">Readiness Score</div>
    <div class="gap-readiness-ring">
      <svg width="100" height="100" viewBox="0 0 100 100">
        <circle cx="50" cy="50" r="40" fill="none"
                stroke="rgba(255,255,255,.07)" stroke-width="8"/>
        <circle cx="50" cy="50" r="40" fill="none"
                stroke="@ringColor"
                stroke-width="8"
                stroke-dasharray="@circumference.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                stroke-dashoffset="@circumference.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                stroke-linecap="round"
                transform="rotate(-90 50 50)"
                id="readinessCircle"
                data-score="@score"
                style="transition: stroke-dashoffset 1s ease;"/>
      </svg>
      <div class="gap-readiness-num">@score%</div>
    </div>
    <div class="gap-readiness-sub">
      @Model.Summary.FeaturesMet of @Model.Summary.TotalFeatures features meet the ideal
    </div>
  </div>

  <div class="gap-summary-row">
    <div class="gap-summary-cell">
      <div class="gap-summary-num gsn-green">@Model.Summary.FeaturesMet</div>
      <div class="gap-summary-tag">Met</div>
    </div>
    <div class="gap-summary-cell">
      <div class="gap-summary-num gsn-amber">@Model.Summary.MediumPriorityGaps</div>
      <div class="gap-summary-tag">Medium</div>
    </div>
    <div class="gap-summary-cell">
      <div class="gap-summary-num gsn-red">@Model.Summary.HighPriorityGaps</div>
      <div class="gap-summary-tag">Critical</div>
    </div>
  </div>

  @if (Model.CriticalGaps.Any())
  {
    <div>
      <div class="gap-section-title gst-red">● Critical Gaps</div>
      @foreach (var gap in Model.CriticalGaps)
      {
        <div class="gap-item-card gi-red">
          <div class="gap-item-top">
            <span class="gap-item-name">@gap.Feature</span>
            <span class="gap-item-val giv-red">@gap.StudentValue / @gap.IdealValue needed</span>
          </div>
          <div class="gap-item-advice">@gap.Advice</div>
        </div>
      }
    </div>
  }

  @if (Model.Gaps.Any())
  {
    <div>
      <div class="gap-section-title gst-amber">⚠ Gaps to Address</div>
      @foreach (var gap in Model.Gaps)
      {
        <div class="gap-item-card gi-amber">
          <div class="gap-item-top">
            <span class="gap-item-name">@gap.Feature</span>
            <span class="gap-item-val giv-amber">@gap.StudentValue / @gap.IdealValue needed</span>
          </div>
          <div class="gap-item-advice">@gap.Advice</div>
        </div>
      }
    </div>
  }

  @if (Model.Strengths.Any())
  {
    <div>
      <div class="gap-section-title gst-green">✓ Your Strengths</div>
      @foreach (var s in Model.Strengths)
      {
        <div class="strength-row">
          <span class="strength-name">@s.Feature</span>
          <span class="strength-badge">✓ Met</span>
        </div>
      }
    </div>
  }

</div>