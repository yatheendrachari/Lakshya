@{
    ViewData["Title"] = "Home - CareerPath";
}

@section styles{
<link rel="stylesheet" href="~/css/Home.css" asp-append-version="true"/>

}

<!-- HERO SECTION -->
<section class="home-hero">
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>

    <div class="container position-relative">
        <div class="row g-5 align-items-center">
            <!-- Left Column -->
            <div class="col-lg-6">
                <!-- Badge -->
                <div class="hero-badge">
                    <span class="hero-badge-dot"></span>
                    AI-Powered &bull; 95.64% Accuracy &bull; 90 Career Paths
                </div>

                <h1 class="hero-title">
                    Your AI Career Guide to <em>Success</em>
                </h1>

                <p class="hero-sub">
                    Upload your resume and let our advanced AI analyze your skills across 15 domains. Get personalized career predictions, skill gap analysis, and custom learning paths—all in under 3 seconds.
                </p>

                <!-- CTA Buttons -->
                <div class="d-flex flex-column flex-sm-row gap-3 mb-5">
                    @if(User.Identity.IsAuthenticated)
                    {
                        <a class="btn-hero-primary">
                            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M11 16V7.85l-2.6 2.6L7 9l5-5 5 5-1.4 1.45-2.6-2.6V16h-2zm-5 4v-5h2v3h8v-3h2v5H6z"/>
                            </svg>
                            Upload Resume
                            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M16.175 13H5q-.425 0-.713-.288T4 12q0-.425.288-.713T5 11h11.175l-4.9-4.9q-.3-.3-.288-.7t.313-.7q.3-.275.7-.288t.7.288l6.6 6.6q.15.15.213.325t.062.375q0 .2-.063.375t-.212.325l-6.6 6.6q-.275.275-.687.275T11.3 19.3q-.3-.3-.3-.713t.3-.712L16.175 13z"/>
                            </svg>
                        </a>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn-hero-primary">
                            Get Started
                            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M16.175 13H5q-.425 0-.713-.288T4 12q0-.425.288-.713T5 11h11.175l-4.9-4.9q-.3-.3-.288-.7t.313-.7q.3-.275.7-.288t.7.288l6.6 6.6q.15.15.213.325t.062.375q0 .2-.063.375t-.212.325l-6.6 6.6q-.275.275-.687.275T11.3 19.3q-.3-.3-.3-.713t.3-.712L16.175 13z"/>
                            </svg>
                        </a>
                        <a href="#demo" class="btn-hero-outline">View Demo</a>
                    }
                </div>

                <!-- Trust indicators -->
                <div class="trust-row">
                    <div class="trust-item"><span class="trust-dot"></span><span>No credit card required</span></div>
                    <div class="trust-item"><span class="trust-dot"></span><span>Free skill analysis</span></div>
                    <div class="trust-item"><span class="trust-dot"></span><span>Instant results</span></div>
                </div>
            </div>

            <!-- Right Column - Dashboard Preview -->
            <div class="col-lg-6 position-relative">
                <div class="dash-card">
                    <!-- Header -->
                    <div class="dash-header">
                        <span class="dash-title">Career Analysis</span>
                        <span class="dash-complete-badge">Complete</span>
                    </div>

                    <!-- Top Predictions -->
                    <div class="vstack gap-2 mb-3">
                        <!-- Prediction 1 -->
                        <div class="pred-row">
                            <div class="pred-rank-badge">#1</div>
                            <div class="flex-grow-1">
                                <div class="pred-name">Machine Learning Engineer</div>
                                <div class="pred-bar-wrap">
                                    <div class="pred-bar"><div class="pred-bar-fill" style="width:94%"></div></div>
                                    <span class="pred-pct">94.2%</span>
                                </div>
                            </div>
                        </div>
                        <!-- Prediction 2 -->
                        <div class="pred-row">
                            <div class="pred-rank-badge r2">#2</div>
                            <div class="flex-grow-1">
                                <div class="pred-name">Data Scientist</div>
                                <div class="pred-bar-wrap">
                                    <div class="pred-bar"><div class="pred-bar-fill r2" style="width:89%"></div></div>
                                    <span class="pred-pct">89.7%</span>
                                </div>
                            </div>
                        </div>
                        <!-- Prediction 3 -->
                        <div class="pred-row">
                            <div class="pred-rank-badge r3">#3</div>
                            <div class="flex-grow-1">
                                <div class="pred-name">AI Research Engineer</div>
                                <div class="pred-bar-wrap">
                                    <div class="pred-bar"><div class="pred-bar-fill r3" style="width:85%"></div></div>
                                    <span class="pred-pct">85.3%</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Skill pills -->
                    <div class="dash-skills">
                        <span class="dash-skill-pill">Python</span>
                        <span class="dash-skill-pill">ML / AI</span>
                        <span class="dash-skill-pill">Data Science</span>
                        <span class="dash-skill-pill">+9 more</span>
                    </div>
                </div>

                <!-- Floating stats -->
                <div class="dash-float-card position-absolute d-none d-lg-block" style="top:3rem;right:-1rem;max-width:10rem;z-index:10;">
                    <div class="p-3 text-center">
                        <div class="small fw-semibold mb-1" style="color:var(--muted);">Accuracy</div>
                        <div style="font-family:var(--f-display);font-size:1.5rem;font-weight:800;color:var(--accent2);">95.64%</div>
                    </div>
                </div>
                <div class="dash-float-card position-absolute d-none d-lg-block" style="bottom:3rem;left:-1rem;max-width:10rem;z-index:10;">
                    <div class="p-3 text-center">
                        <div class="small fw-semibold mb-1" style="color:var(--muted);">Career Paths</div>
                        <div style="font-family:var(--f-display);font-size:1.5rem;font-weight:800;color:var(--low);">90+</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- HOW IT WORKS SECTION -->
<section id="how-it-works" class="home-hiw">
    <div class="container">
        <div class="text-center mb-5">
            <div class="sec-eyebrow">Simple Process</div>
            <h2 class="sec-heading">How It Works</h2>
            <p class="sec-sub mx-auto">From upload to personalized career roadmap in under 3 seconds</p>
        </div>

        <div class="hiw-grid">
            <!-- Step 1 -->
            <div class="hiw-card">
                <div class="hiw-num">1</div>
                <div class="hiw-title">Upload Your Data</div>
                <p class="hiw-desc">Submit your resume, link your GitHub, and complete a dynamic skill questionnaire.</p>
            </div>
            <!-- Step 2 -->
            <div class="hiw-card">
                <div class="hiw-num">2</div>
                <div class="hiw-title">AI Analysis</div>
                <p class="hiw-desc">Our Groq-powered LLM extracts 15 key features and runs XGBoost classification.</p>
            </div>
            <!-- Step 3 -->
            <div class="hiw-card">
                <div class="hiw-num">3</div>
                <div class="hiw-title">Get Predictions</div>
                <p class="hiw-desc">Receive top 4 career matches from 90 roles with confidence scores and gap analysis.</p>
            </div>
            <!-- Step 4 -->
            <div class="hiw-card">
                <div class="hiw-num">4</div>
                <div class="hiw-title">Start Learning</div>
                <p class="hiw-desc">Follow your personalized learning path with curated resources from top platforms.</p>
            </div>
        </div>

        <!-- Performance Stats -->
        <div class="row g-3 mt-4">
            <div class="col-6 col-md-3">
                <div class="career-stat-card">
                    <div class="stat-number">&lt;3s</div>
                    <div class="stat-label">Response Time</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="career-stat-card">
                    <div class="stat-number">95.64%</div>
                    <div class="stat-label">Model Accuracy</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="career-stat-card">
                    <div class="stat-number">90</div>
                    <div class="stat-label">Career Paths</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="career-stat-card">
                    <div class="stat-number">15</div>
                    <div class="stat-label">Skill Domains</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FEATURES SECTION -->
<section id="features" class="home-features">
    <div class="container">
        <div class="text-center mb-5">
            <div class="sec-eyebrow">Powerful Features</div>
            <h2 class="sec-heading">Everything You Need</h2>
            <p class="sec-sub mx-auto">Enterprise-grade AI career guidance built with cutting-edge technology</p>
        </div>

        <div class="features-grid">
            <!-- Feature 1 -->
            <div class="feat-card">
                <div class="feat-icon-wrap">
                    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zM7 11h2v2H7v-2zm4 0h2v2h-2v-2zm4 0h2v2h-2v-2z"/></svg>
                </div>
                <div class="feat-title">AI-Powered Analysis</div>
                <p class="feat-desc">Groq-powered LLM extracts 15 key features from your resume and GitHub activity with deep contextual understanding.</p>
            </div>
            <!-- Feature 2 -->
            <div class="feat-card">
                <div class="feat-icon-wrap amber">
                    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z"/><path d="M12.5 7H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
                </div>
                <div class="feat-title">XGBoost Classifier</div>
                <p class="feat-desc">95.64% accuracy across 90 career roles spanning 15 domains. Trained on real industry data.</p>
            </div>
            <!-- Feature 3 -->
            <div class="feat-card">
                <div class="feat-icon-wrap green">
                    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M3.5 18.49l6-6.01 4 4L22 6.92l-1.41-1.41-7.09 7.97-4-4L2 16.99z"/></svg>
                </div>
                <div class="feat-title">Skill Gap Analysis</div>
                <p class="feat-desc">Identify exactly what skills you need to master for your target career with priority rankings.</p>
            </div>
            <!-- Feature 4 -->
            <div class="feat-card">
                <div class="feat-icon-wrap red">
                    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 4h5v8l-2.5-1.5L6 12V4z"/></svg>
                </div>
                <div class="feat-title">Personalized Learning Paths</div>
                <p class="feat-desc">Curated progression from beginner to advanced with resources from YouTube, Udemy, Coursera, and academic papers.</p>
            </div>
            <!-- Feature 5 -->
            <div class="feat-card">
                <div class="feat-icon-wrap red">
                    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M7 2v11h3v9l7-12h-4l4-8z"/></svg>
                </div>
                <div class="feat-title">Lightning Fast</div>
                <p class="feat-desc">Multi-layer caching and parallel processing deliver complete analysis in under 3 seconds.</p>
            </div>
            <!-- Feature 6 -->
            <div class="feat-card">
                <div class="feat-icon-wrap muted">
                    <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
                </div>
                <div class="feat-title">90-Career Catalog</div>
                <p class="feat-desc">Explore comprehensive career profiles with salary data, job trends, and skill requirements.</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA SECTION -->
@if (!User.Identity.IsAuthenticated)
{
    <section class="home-cta">
        <div class="container">
            <div class="row align-items-center g-4">
                <div class="col-lg-8">
                    <h2 class="cta-title">Ready to Discover Your <em>Career Path?</em></h2>
                    <p class="cta-sub">Join thousands of students who've found their ideal career with AI-powered guidance. Get started in less than 5 minutes.</p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <a asp-area="Identity" asp-page="/Account/register" class="btn-cta-primary">
                        Get Started Free
                        <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M16.175 13H5q-.425 0-.713-.288T4 12q0-.425.288-.713T5 11h11.175l-4.9-4.9q-.3-.3-.288-.7t.313-.7q.3-.275.7-.288t.7.288l6.6 6.6q.15.15.213.325t.062.375q0 .2-.063.375t-.212.325l-6.6 6.6q-.275.275-.687.275T11.3 19.3q-.3-.3-.3-.713t.3-.712L16.175 13z"/>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </section>
}