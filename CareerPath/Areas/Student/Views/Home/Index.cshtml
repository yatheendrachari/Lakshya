@{
    ViewData["Title"] = "Home - CareerPath";
}

<!-- HERO SECTION -->
<section class="position-relative py-5 overflow-hidden" style="padding-top: 8rem; padding-bottom: 5rem;">
    <!-- Background gradients -->
    <div class="position-absolute top-0 start-0 w-100 h-100" style="z-index: -1; opacity: 0.15;">
        <div class="position-absolute rounded-circle" style="top: 0; left: 25%; width: 24rem; height: 24rem; background: radial-gradient(circle, #325d88, transparent); filter: blur(80px);"></div>
        <div class="position-absolute rounded-circle" style="top: 5rem; right: 25%; width: 24rem; height: 24rem; background: radial-gradient(circle, #29abe0, transparent); filter: blur(80px);"></div>
    </div>

    <div class="container">
        <div class="row g-5 align-items-center">
            <!-- Left Column -->
            <div class="col-lg-6">
                <!-- Badge -->
                <div class="d-inline-flex align-items-center gap-2 px-3 py-2 rounded-pill bg-primary bg-opacity-10 border border-primary mb-4">
                    <svg class="text-primary" width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M9.153 5.408C10.42 3.136 11.053 2 12 2c.947 0 1.58 1.136 2.847 3.408l.328.588c.36.646.54.969.82 1.182.28.213.63.292 1.33.45l.636.144c2.46.557 3.689.835 3.982 1.776.292.94-.546 1.921-2.223 3.882l-.434.507c-.476.557-.715.836-.822 1.18-.107.345-.071.717.001 1.46l.066.677c.253 2.617.38 3.925-.386 4.506-.766.582-1.918.051-4.22-1.009l-.597-.274c-.654-.302-.981-.452-1.328-.452-.347 0-.674.15-1.328.452l-.596.274c-2.303 1.06-3.455 1.59-4.22 1.01-.767-.582-.64-1.89-.387-4.507l.066-.676c.072-.744.108-1.116 0-1.46-.106-.345-.345-.624-.821-1.18l-.434-.508c-1.677-1.96-2.515-2.941-2.223-3.882.293-.941 1.523-1.22 3.983-1.776l.636-.144c.699-.158 1.048-.237 1.329-.45.28-.213.46-.536.82-1.182l.328-.588z"/>
                    </svg>
                    <span class="small fw-semibold text-primary">
                        AI-Powered • 95.64% Accuracy • 90 Career Paths
                    </span>
                </div>

                <h1 class="display-3 fw-bold text-dark mb-4 lh-sm">
                    Your AI Career Guide to 
                    <span style="background: linear-gradient(90deg, #325d88, #29abe0); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
                        Success
                    </span>
                </h1>

                <p class="lead text-muted mb-4">
                    Upload your resume and let our advanced AI analyze your skills across 15 domains. Get personalized career predictions, skill gap analysis, and custom learning paths—all in under 3 seconds.
                </p>

                <!-- CTA Buttons -->
                <div class="d-flex flex-column flex-sm-row gap-3 mb-5">
                    @if(User.Identity.IsAuthenticated)
                    {
                        <a  class="btn btn-lg btn-primary shadow" style="background: linear-gradient(90deg, #325d88, #29abe0); border: none;">
                            <svg class="me-2" width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M11 16V7.85l-2.6 2.6L7 9l5-5 5 5-1.4 1.45-2.6-2.6V16h-2zm-5 4v-5h2v3h8v-3h2v5H6z"/>
                            </svg>
                            Upload Resume
                            <svg class="ms-2" width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M16.175 13H5q-.425 0-.713-.288T4 12q0-.425.288-.713T5 11h11.175l-4.9-4.9q-.3-.3-.288-.7t.313-.7q.3-.275.7-.288t.7.288l6.6 6.6q.15.15.213.325t.062.375q0 .2-.063.375t-.212.325l-6.6 6.6q-.275.275-.687.275T11.3 19.3q-.3-.3-.3-.713t.3-.712L16.175 13z"/>
                            </svg>
                        </a>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-lg btn-primary shadow" style="background: linear-gradient(90deg, #325d88, #29abe0); border: none;">
                            
                            Get Started
                            <svg class="ms-2" width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M16.175 13H5q-.425 0-.713-.288T4 12q0-.425.288-.713T5 11h11.175l-4.9-4.9q-.3-.3-.288-.7t.313-.7q.3-.275.7-.288t.7.288l6.6 6.6q.15.15.213.325t.062.375q0 .2-.063.375t-.212.325l-6.6 6.6q-.275.275-.687.275T11.3 19.3q-.3-.3-.3-.713t.3-.712L16.175 13z"/>
                            </svg>
                        </a>
                        <a href="#demo" class="btn btn-lg btn-outline-primary">View Demo</a>

                    }
                </div>

                <!-- Trust indicators -->
                <div class="d-flex flex-wrap gap-4 small text-muted">
                    <div class="d-flex align-items-center gap-2">
                        <span class="rounded-circle bg-success" style="width: 8px; height: 8px;"></span>
                        <span>No credit card required</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="rounded-circle bg-success" style="width: 8px; height: 8px;"></span>
                        <span>Free skill analysis</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="rounded-circle bg-success" style="width: 8px; height: 8px;"></span>
                        <span>Instant results</span>
                    </div>
                </div>
            </div>

            <!-- Right Column - Dashboard Preview -->
            <div class="col-lg-6 position-relative">
                <div class="card border shadow-lg rounded-4 overflow-hidden">
                    <div class="card-body p-4 position-relative">
                        <!-- Glassmorphism overlay -->
                        <div class="position-absolute top-0 end-0 rounded-circle" style="width: 16rem; height: 16rem; background: radial-gradient(circle, rgba(50, 93, 136, 0.1), transparent); filter: blur(60px);"></div>
                        
                        <!-- Mock Dashboard -->
                        <div class="position-relative">
                            <!-- Header -->
                            <div class="d-flex justify-content-between align-items-center pb-3 border-bottom mb-4">
                                <h5 class="fw-semibold mb-0">Career Analysis</h5>
                                <span class="badge bg-success">Complete</span>
                            </div>

                            <!-- Top Predictions -->
                            <div class="vstack gap-3 mb-4">
                                <!-- Prediction 1 -->
                                <div class="d-flex align-items-center gap-3 p-3 rounded-3 bg-light border">
                                    <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0 text-white fw-bold" style="width: 2.5rem; height: 2.5rem; background: linear-gradient(135deg, #325d88, #29abe0);">
                                        #1
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="small fw-semibold text-truncate">Machine Learning Engineer</div>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height: 6px; max-width: 100px;">
                                                <div class="progress-bar" style="width: 94%; background: linear-gradient(90deg, #325d88, #29abe0);"></div>
                                            </div>
                                            <span class="small text-muted">94.2%</span>
                                        </div>
                                    </div>
                                    <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 1.5rem; height: 1.5rem;">
                                        <svg class="text-success" width="14" height="14" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z"/>
                                        </svg>
                                    </div>
                                </div>

                                <!-- Prediction 2 -->
                                <div class="d-flex align-items-center gap-3 p-3 rounded-3 bg-light border">
                                    <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0 text-white fw-bold" style="width: 2.5rem; height: 2.5rem; background: linear-gradient(135deg, #29abe0, #93c54b);">
                                        #2
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="small fw-semibold text-truncate">Data Scientist</div>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height: 6px; max-width: 100px;">
                                                <div class="progress-bar" style="width: 89%; background: linear-gradient(90deg, #29abe0, #93c54b);"></div>
                                            </div>
                                            <span class="small text-muted">89.7%</span>
                                        </div>
                                    </div>
                                    <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 1.5rem; height: 1.5rem;">
                                        <svg class="text-success" width="14" height="14" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z"/>
                                        </svg>
                                    </div>
                                </div>

                                <!-- Prediction 3 -->
                                <div class="d-flex align-items-center gap-3 p-3 rounded-3 bg-light border">
                                    <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0 text-white fw-bold" style="width: 2.5rem; height: 2.5rem; background: linear-gradient(135deg, #93c54b, #f47c3c);">
                                        #3
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="small fw-semibold text-truncate">AI Research Engineer</div>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height: 6px; max-width: 100px;">
                                                <div class="progress-bar bg-success" style="width: 85%;"></div>
                                            </div>
                                            <span class="small text-muted">85.3%</span>
                                        </div>
                                    </div>
                                    <div class="rounded-circle bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 1.5rem; height: 1.5rem;">
                                        <svg class="text-secondary" width="14" height="14" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z"/>
                                        </svg>
                                    </div>
                                </div>
                            </div>

                            <!-- Skills Overview -->
                            <div class="pt-3 border-top">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="small fw-semibold">Skill Match</span>
                                    <span class="small text-muted">12/15 domains</span>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar rounded" style="width: 80%; background: linear-gradient(90deg, #325d88, #29abe0);"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Floating stats -->
                <div class="card border shadow position-absolute d-none d-lg-block" style="top: 3rem; right: -1rem; max-width: 10rem; z-index: 10;">
                    <div class="card-body p-3 text-center">
                        <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
                            <svg class="text-primary" width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z"/>
                                <path d="M12.5 7H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
                            </svg>
                            <span class="small fw-semibold text-muted">Accuracy</span>
                        </div>
                        <div class="h3 fw-bold mb-0 text-primary">95.64%</div>
                    </div>
                </div>

                <div class="card border shadow position-absolute d-none d-lg-block" style="bottom: 3rem; left: -1rem; max-width: 10rem; z-index: 10;">
                    <div class="card-body p-3 text-center">
                        <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
                            <svg class="text-success" width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z"/>
                            </svg>
                            <span class="small fw-semibold text-muted">Career Paths</span>
                        </div>
                        <div class="h3 fw-bold mb-0 text-success">90+</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- HOW IT WORKS SECTION -->
<section id="how-it-works" class="py-5 bg-light">
    <div class="container py-5">
        <!-- Section Header -->
        <div class="text-center mb-5">
            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-4 py-2 rounded-pill fw-semibold mb-3">
                Simple Process
            </span>
            <h2 class="display-5 fw-bold mb-3">How It Works</h2>
            <p class="lead text-muted mx-auto" style="max-width: 40rem;">
                From upload to personalized career roadmap in under 3 seconds
            </p>
        </div>

        <!-- Steps -->
        <div class="position-relative">
            <!-- Connection Line -->
            <div class="d-none d-lg-block position-absolute top-50 start-0 end-0 translate-middle-y border-top border-2 border-primary opacity-25"></div>

            <div class="row g-4 position-relative">
                <!-- Step 1 -->
                <div class="col-md-6 col-lg-3">
                    <div class="card border-0 shadow h-100">
                        <span class="position-absolute top-0 end-0 translate-middle badge rounded-circle bg-light border border-3 border-white text-dark fw-bold" style="width: 2rem; height: 2rem; line-height: 2rem;">1</span>
                        <div class="card-body p-4">
                            <div class="rounded-3 d-inline-flex align-items-center justify-content-center mb-3 text-white" style="width: 3.5rem; height: 3.5rem; background: linear-gradient(135deg, #325d88, #29abe0);">
                                <svg width="28" height="28" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M11 16V7.85l-2.6 2.6L7 9l5-5 5 5-1.4 1.45-2.6-2.6V16h-2zm-5 4v-5h2v3h8v-3h2v5H6z"/>
                                </svg>
                            </div>
                            <h5 class="fw-bold mb-3">Upload Your Data</h5>
                            <p class="text-muted mb-0">
                                Submit your resume, link your GitHub, and complete a dynamic skill questionnaire.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Step 2 -->
                <div class="col-md-6 col-lg-3">
                    <div class="card border-0 shadow h-100">
                        <span class="position-absolute top-0 end-0 translate-middle badge rounded-circle bg-light border border-3 border-white text-dark fw-bold" style="width: 2rem; height: 2rem; line-height: 2rem;">2</span>
                        <div class="card-body p-4">
                            <div class="rounded-3 d-inline-flex align-items-center justify-content-center mb-3 text-white" style="width: 3.5rem; height: 3.5rem; background: linear-gradient(135deg, #29abe0, #93c54b);">
                                <svg width="28" height="28" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zM7 11h2v2H7v-2zm4 0h2v2h-2v-2zm4 0h2v2h-2v-2z"/>
                                </svg>
                            </div>
                            <h5 class="fw-bold mb-3">AI Analysis</h5>
                            <p class="text-muted mb-0">
                                Our Groq-powered LLM extracts 15 key features and runs XGBoost classification.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Step 3 -->
                <div class="col-md-6 col-lg-3">
                    <div class="card border-0 shadow h-100">
                        <span class="position-absolute top-0 end-0 translate-middle badge rounded-circle bg-light border border-3 border-white text-dark fw-bold" style="width: 2rem; height: 2rem; line-height: 2rem;">3</span>
                        <div class="card-body p-4">
                            <div class="rounded-3 d-inline-flex align-items-center justify-content-center mb-3 text-white" style="width: 3.5rem; height: 3.5rem; background: linear-gradient(135deg, #93c54b, #f47c3c);">
                                <svg width="28" height="28" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z"/>
                                    <path d="M12.5 7H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
                                </svg>
                            </div>
                            <h5 class="fw-bold mb-3">Get Predictions</h5>
                            <p class="text-muted mb-0">
                                Receive top 4 career matches from 90 roles with confidence scores and gap analysis.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Step 4 -->
                <div class="col-md-6 col-lg-3">
                    <div class="card border-0 shadow h-100">
                        <span class="position-absolute top-0 end-0 translate-middle badge rounded-circle bg-light border border-3 border-white text-dark fw-bold" style="width: 2rem; height: 2rem; line-height: 2rem;">4</span>
                        <div class="card-body p-4">
                            <div class="rounded-3 d-inline-flex align-items-center justify-content-center mb-3 text-white" style="width: 3.5rem; height: 3.5rem; background: linear-gradient(135deg, #f47c3c, #d9534f);">
                                <svg width="28" height="28" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
                                </svg>
                            </div>
                            <h5 class="fw-bold mb-3">Start Learning</h5>
                            <p class="text-muted mb-0">
                                Follow your personalized learning path with curated resources from top platforms.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Performance Stats -->
        <div class="row g-4 mt-4">
            <div class="col-6 col-md-3">
                <div class="card border text-center p-4">
                    <div class="h2 fw-bold mb-1" style="background: linear-gradient(90deg, #325d88, #29abe0); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
                        &lt;3s
                    </div>
                    <div class="small text-muted">Response Time</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border text-center p-4">
                    <div class="h2 fw-bold mb-1" style="background: linear-gradient(90deg, #325d88, #29abe0); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
                        95.64%
                    </div>
                    <div class="small text-muted">Model Accuracy</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border text-center p-4">
                    <div class="h2 fw-bold mb-1" style="background: linear-gradient(90deg, #325d88, #29abe0); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
                        90
                    </div>
                    <div class="small text-muted">Career Paths</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border text-center p-4">
                    <div class="h2 fw-bold mb-1" style="background: linear-gradient(90deg, #325d88, #29abe0); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
                        15
                    </div>
                    <div class="small text-muted">Skill Domains</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FEATURES SECTION -->
<section id="features" class="py-5">
    <div class="container py-5">
        <!-- Section Header -->
        <div class="text-center mb-5">
            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-4 py-2 rounded-pill fw-semibold mb-3">
                Powerful Features
            </span>
            <h2 class="display-5 fw-bold mb-3">Everything You Need</h2>
            <p class="lead text-muted mx-auto" style="max-width: 40rem;">
                Enterprise-grade AI career guidance built with cutting-edge technology
            </p>
        </div>

        <!-- Features Grid -->
        <div class="row g-4">
            <!-- Feature 1 -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="rounded-3 d-inline-flex align-items-center justify-content-center mb-3 bg-primary text-white" style="width: 3rem; height: 3rem;">
                            <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zM7 11h2v2H7v-2zm4 0h2v2h-2v-2zm4 0h2v2h-2v-2z"/>
                            </svg>
                        </div>
                        <h5 class="fw-bold mb-3">AI-Powered Analysis</h5>
                        <p class="text-muted mb-0">
                            Groq-powered LLM extracts 15 key features from your resume and GitHub activity with deep contextual understanding.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Feature 2 -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="rounded-3 d-inline-flex align-items-center justify-content-center mb-3 bg-info text-white" style="width: 3rem; height: 3rem;">
                            <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z"/>
                                <path d="M12.5 7H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
                            </svg>
                        </div>
                        <h5 class="fw-bold mb-3">XGBoost Classifier</h5>
                        <p class="text-muted mb-0">
                            95.64% accuracy across 90 career roles spanning 15 domains. Trained on real industry data.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Feature 3 -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="rounded-3 d-inline-flex align-items-center justify-content-center mb-3 bg-success text-white" style="width: 3rem; height: 3rem;">
                            <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M3.5 18.49l6-6.01 4 4L22 6.92l-1.41-1.41-7.09 7.97-4-4L2 16.99z"/>
                            </svg>
                        </div>
                        <h5 class="fw-bold mb-3">Skill Gap Analysis</h5>
                        <p class="text-muted mb-0">
                            Identify exactly what skills you need to master for your target career with priority rankings.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Feature 4 -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="rounded-3 d-inline-flex align-items-center justify-content-center mb-3 bg-warning text-white" style="width: 3rem; height: 3rem;">
                            <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 4h5v8l-2.5-1.5L6 12V4z"/>
                            </svg>
                        </div>
                        <h5 class="fw-bold mb-3">Personalized Learning Paths</h5>
                        <p class="text-muted mb-0">
                            Curated progression from beginner to advanced with resources from YouTube, Udemy, Coursera, and academic papers.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Feature 5 -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="rounded-3 d-inline-flex align-items-center justify-content-center mb-3 bg-danger text-white" style="width: 3rem; height: 3rem;">
                            <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M7 2v11h3v9l7-12h-4l4-8z"/>
                            </svg>
                        </div>
                        <h5 class="fw-bold mb-3">Lightning Fast</h5>
                        <p class="text-muted mb-0">
                            Multi-layer caching and parallel processing deliver complete analysis in under 3 seconds.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Feature 6 -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="rounded-3 d-inline-flex align-items-center justify-content-center mb-3 bg-secondary text-white" style="width: 3rem; height: 3rem;">
                            <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                            </svg>
                        </div>
                        <h5 class="fw-bold mb-3">90-Career Catalog</h5>
                        <p class="text-muted mb-0">
                            Explore comprehensive career profiles with salary data, job trends, and skill requirements.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA SECTION -->
@if (!User.Identity.IsAuthenticated)
{
    <section class="py-5 text-white" style="background: linear-gradient(135deg, #325d88, #29abe0, #93c54b);">
        <div class="container py-5">
            <div class="row align-items-center g-4">
                <div class="col-lg-8">
                    <h2 class="display-5 fw-bold mb-3">Ready to Discover Your Career Path?</h2>
                    <p class="lead mb-0 opacity-90">
                        Join thousands of students who've found their ideal career with AI-powered guidance. Get started in less than 5 minutes.
                    </p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <a asp-area="Identity" asp-page="/Account/register" class="btn btn-light btn-lg shadow px-5">
                        Get Started Free
                        <svg class="ms-2" width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M16.175 13H5q-.425 0-.713-.288T4 12q0-.425.288-.713T5 11h11.175l-4.9-4.9q-.3-.3-.288-.7t.313-.7q.3-.275.7-.288t.7.288l6.6 6.6q.15.15.213.325t.062.375q0 .2-.063.375t-.212.325l-6.6 6.6q-.275.275-.687.275T11.3 19.3q-.3-.3-.3-.713t.3-.712L16.175 13z"/>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </section>

}
