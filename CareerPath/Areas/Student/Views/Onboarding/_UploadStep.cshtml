<div class="text-center mb-4">
    <div class="rounded-3 d-inline-flex align-items-center justify-content-center mb-3 text-white" style="width: 4rem; height: 4rem; background: linear-gradient(135deg, #325d88, #29abe0);">
        <svg width="32" height="32" fill="currentColor" viewBox="0 0 24 24">
            <path d="M11 16V7.85l-2.6 2.6L7 9l5-5 5 5-1.4 1.45-2.6-2.6V16h-2zm-5 4v-5h2v3h8v-3h2v5H6z"/>
        </svg>
    </div>
    <h3 class="fw-bold mb-2">Let's Get Started</h3>
    <p class="text-muted mb-0">
        Upload your resume and link your GitHub to help us understand your skills better.
        <br><small class="text-muted">Both are optional, but more data = better predictions.</small>
    </p>
</div>

<form method="post" asp-action="Analyze" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    
    <!-- Resume Upload -->
    <div class="mb-4">
        <label class="form-label fw-semibold d-flex align-items-center gap-2">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zM6 20V4h7v5h5v11H6z"/>
            </svg>
            Resume (PDF)
            <span class="badge bg-secondary bg-opacity-10 text-secondary ms-auto">Optional</span>
        </label>
        <div class="border border-2 border-dashed rounded-3 p-4 text-center" style="border-color: #dee2e6 !important;">
            <input type="file" 
                   class="form-control d-none" 
                   id="resumeFile" 
                   name="resume" 
                   accept=".pdf"
                   onchange="showFilePreview(this)">
            
            <div id="resumePlaceholder">
                <svg class="text-muted mb-2" width="40" height="40" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M19.35 10.04C18.67 6.59 15.64 4 12 4c-1.48 0-2.85.43-4.01 1.17l1.46 1.46C10.21 6.23 11.08 6 12 6c3.04 0 5.5 2.46 5.5 5.5v.5H19c1.66 0 3 1.34 3 3 0 1.13-.64 2.11-1.56 2.62l1.45 1.45C23.16 18.16 24 16.68 24 15c0-2.64-2.05-4.78-4.65-4.96zM3 5.27l2.75 2.74C2.56 8.15 0 10.77 0 14c0 3.31 2.69 6 6 6h11.73l2 2L21 20.73 4.27 4 3 5.27zM7.73 10l8 8H6c-2.21 0-4-1.79-4-4s1.79-4 4-4h1.73z"/>
                </svg>
                <p class="mb-2 fw-semibold">Drag & drop your resume here</p>
                <p class="text-muted small mb-2">or</p>
                <button type="button" class="btn btn-sm btn-outline-primary" onclick="document.getElementById('resumeFile').click()">
                    Browse Files
                </button>
                <p class="text-muted small mt-2 mb-0">PDF format, max 5MB</p>
            </div>

            <div id="resumeSelected" class="d-none">
                <div class="d-flex align-items-center justify-content-center gap-3">
                    <svg class="text-success" width="32" height="32" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                    </svg>
                    <div class="text-start">
                        <p class="mb-0 fw-semibold" id="resumeFileName">resume.pdf</p>
                        <p class="text-muted small mb-0" id="resumeFileSize">2.4 MB</p>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-danger ms-auto" onclick="clearFilePreview()">
                        Remove
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- GitHub Username -->
    <div class="mb-4">
        <label for="githubUsername" class="form-label fw-semibold d-flex align-items-center gap-2">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub Username
            <span class="badge bg-secondary bg-opacity-10 text-secondary ms-auto">Optional</span>
        </label>
        <div class="input-group">
            <span class="input-group-text bg-light border-end-0">
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
            </span>
            <input type="text" 
                   class="form-control border-start-0" 
                   id="githubUsername" 
                   name="githubUsername" 
                   placeholder="your-username"
                   style="border-left: 0;">
        </div>
        <small class="form-text text-muted">
            We'll analyze your repositories, languages, and contribution patterns
        </small>
    </div>

    <!-- Info Alert -->
    <div class="alert alert-info bg-info bg-opacity-10 border-info d-flex align-items-start gap-3 mb-4">
        <svg class="text-info flex-shrink-0 mt-1" width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
        </svg>
        <div class="small">
            <strong>Don't have these yet?</strong> No problem! We'll ask you detailed questions to understand your skills and interests.
        </div>
    </div>

    <!-- Submit Button -->
    <button type="submit" class="btn btn-primary w-100 py-3 fw-semibold" style="background: linear-gradient(90deg, #325d88, #29abe0); border: none;">
        Continue
        <svg class="ms-2" width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
            <path d="M16.175 13H5q-.425 0-.713-.288T4 12q0-.425.288-.713T5 11h11.175l-4.9-4.9q-.3-.3-.288-.7t.313-.7q.3-.275.7-.288t.7.288l6.6 6.6q.15.15.213.325t.062.375q0 .2-.063.375t-.212.325l-6.6 6.6q-.275.275-.687.275T11.3 19.3q-.3-.3-.3-.713t.3-.712L16.175 13z"/>
        </svg>
    </button>
</form>

<script>
    // JS ONLY for visual file preview - NOT for handling upload
    function showFilePreview(input) {
        const file = input.files[0];
        if(file) {
            document.getElementById('resumePlaceholder').classList.add('d-none');
            document.getElementById('resumeSelected').classList.remove('d-none');
            document.getElementById('resumeFileName').textContent = file.name;
            document.getElementById('resumeFileSize').textContent = (file.size / 1024 / 1024).toFixed(2) + ' MB';
        }
    }

    function clearFilePreview() {
        document.getElementById('resumeFile').value = '';
        document.getElementById('resumePlaceholder').classList.remove('d-none');
        document.getElementById('resumeSelected').classList.add('d-none');
    }
</script>
